# =============================================================
# arremateai-orchestrator — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.

# --- Servidor ---
SERVER_PORT=8087
ORCHESTRATOR_LOG_LEVEL=DEBUG

# --- URLs dos serviços dependentes ---
PROPERTY_CATALOG_URL=http://localhost:8082
MEDIA_URL=http://localhost:8083
VENDOR_URL=http://localhost:8084
USERPROFILE_URL=http://localhost:8085
NOTIFICATION_URL=http://localhost:8086

# --- Segurança interna ---
INTERNAL_API_KEY=

# --- Contexto administrativo ---
ADMIN_USER_ID=
